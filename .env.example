# 123 网盘 P123 账户配置
# 账户 ID（从 config.json 中获取）
P123_ACCOUNT_ID=your_account_id

# 账户密码
P123_PASSWORD=your_password

# 上传到的父目录 ID（默认为 0 表示根目录）
P123_PARENT_ID=0

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 网盘挂载路径（用于本地访问）
MEDIA_PATH=/app/media

# 归档目录路径（处理完的 JSON 文件存放位置）
ARCHIVE_PATH=/app/media/archive
